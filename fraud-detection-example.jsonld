      "sro:goalName": "Prevent Financial Fraud",
      "schema:description": "Detect and prevent fraudulent transactions in real-time to protect customers and reduce financial losses",
      "sro:goalType": "BUSINESS",
      "sro:priority": "HIGH",
      "sro:status": "ACCEPTED",
      "sro:successCriteria": "Reduce fraud losses by 80%, detect 95% of fraudulent transactions within 1 second"
